# Copy to .env and fill in. In production these come from a secrets manager.

# Reject unsigned events and unknown agents. Keep true in production.
EAL_STRICT_MODE=true

# Storage: "memory" | "sqlite:///eal.db" | "postgresql+psycopg://user:pass@host/db"
EAL_DATABASE_URL=memory

# Append-only signed audit ledger location (optional; in-memory if unset).
EAL_LEDGER_PATH=

# Issuer Ed25519 keypair for capability tokens + ledger signing.
# Generate with: python -m earned_autonomy.cli keygen
EAL_ISSUER_PRIVATE_KEY_HEX=
EAL_ISSUER_PUBLIC_KEY_HEX=

EAL_CAPABILITY_TTL_SECONDS=300

# Human/admin auth via OIDC. Set all three for production.
EAL_OIDC_ISSUER=
EAL_OIDC_AUDIENCE=
EAL_OIDC_JWKS_URL=

# Dev-only HMAC bearer secret. Leave EMPTY in production (strict mode will
# refuse to start on dev auth when no OIDC issuer is configured).
EAL_DEV_AUTH_SECRET=

EAL_LOG_LEVEL=INFO
